{
  "name": "ts-platform",
  "private": true,
  "type": "module",
  "description": "A TypeScript monorepo platform for building shared packages, tools, and infrastructure across the Codeminity ecosystem.",
  "license": "MIT",
  "author": "Masoud Fooladi",
  "repository": {
    "type": "git",
    "url": "https://github.com/codeminity/ts-platform"
  },
  "homepage": "https://github.com/codeminity/ts-platform#readme",
  "bugs": {
    "url": "https://github.com/codeminity/ts-platform/issues"
  },
  "sideEffects": false,
  "engines": {
    "node": "^22.13.0 || >=24.0.0"
  },
  "packageManager": "pnpm@11.17.0",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "prepublishOnly": "pnpm build",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint .",
    "format": "prettier --write .",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "changeset publish",
    "validate:api": "tsx scripts/validate-api-run.ts",
    "typecheck": "turbo run typecheck && tsc -p scripts/tsconfig.json --noEmit",
    "verify:package": "tsx scripts/verify-package-run.ts",
    "verify:packages": "tsx scripts/verify-packages-run.ts"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.1",
    "@eslint/js": "^10.0.1",
    "@microsoft/api-extractor": "^7.58.12",
    "@types/node": "^26.1.1",
    "@vitest/coverage-v8": "^4.1.10",
    "eslint": "^10.7.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import-x": "^4.17.1",
    "globals": "^17.7.0",
    "globby": "^16.2.2",
    "jiti": "^2.7.0",
    "prettier": "^3.9.6",
    "publint": "^0.3.21",
    "tsx": "^4.23.1",
    "turbo": "^2.10.5",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.64.0",
    "vitest": "^4.1.10"
  }
}
