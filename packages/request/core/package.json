{
  "name": "@codeminity/request-core",
  "version": "0.0.0",
  "private": false,
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "request",
    "http",
    "typescript",
    "javascript",
    "infrastructure",
    "retry",
    "auth"
  ],
  "type": "module",
  "author": "Masoud Fooladi",
  "description": "Core infrastructure layer for request handling.",
  "license": "MIT",
  "engines": {
    "node": ">=24"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/codeminity/ts-platform.git",
    "directory": "packages/request/core"
  },
  "homepage": "https://github.com/codeminity/ts-platform#readme",
  "bugs": {
    "url": "https://github.com/codeminity/ts-platform/issues"
  },
  "sideEffects": false,
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "pnpm run build:js && pnpm run build:types",
    "build:js": "tsup",
    "build:types": "tsc -p tsconfig.json --emitDeclarationOnly",
    "dev": "tsup --watch"
  },
  "devDependencies": {
    "tsup": "^8.5.1"
  }
}
