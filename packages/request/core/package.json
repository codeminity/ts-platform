{
  "name": "@codeminity/request-core",
  "version": "0.1.1",
  "private": false,
  "description": "Production-ready request infrastructure for retries, authentication, token refresh, queues and shared networking utilities.",
  "keywords": [
    "request",
    "http",
    "typescript",
    "javascript",
    "infrastructure",
    "retry",
    "auth",
    "fetch",
    "network",
    "token",
    "middleware",
    "refresh-token"
  ],
  "license": "MIT",
  "author": "Masoud Fooladi",
  "repository": {
    "type": "git",
    "url": "https://github.com/codeminity/ts-platform.git",
    "directory": "packages/request/core"
  },
  "homepage": "https://github.com/codeminity/ts-platform#readme",
  "bugs": {
    "url": "https://github.com/codeminity/ts-platform/issues"
  },
  "type": "module",
  "sideEffects": false,
  "engines": {
    "node": "^20.19.0 || >=24.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "types": "./dist/index.d.ts",
  "main": "./dist/index.js",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "pnpm run build:js && pnpm run build:types",
    "build:js": "tsup",
    "build:types": "tsc -p tsconfig.json --emitDeclarationOnly",
    "dev": "tsup --watch",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "devDependencies": {
    "tsup": "^8.5.1"
  }
}
