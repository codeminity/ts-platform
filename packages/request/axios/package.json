{
  "name": "@codeminity/axios",
  "version": "0.1.1",
  "private": false,
  "description": "A production-ready Axios adapter with built-in infrastructure for retries, authentication, and advanced request handling.",
  "keywords": [
    "axios",
    "http",
    "request",
    "typescript",
    "javascript",
    "adapter",
    "retry",
    "authentication",
    "interceptors"
  ],
  "license": "MIT",
  "author": "Masoud Fooladi",
  "repository": {
    "type": "git",
    "url": "https://github.com/codeminity/ts-platform.git",
    "directory": "packages/request/axios"
  },
  "homepage": "https://github.com/codeminity/ts-platform#readme",
  "bugs": {
    "url": "https://github.com/codeminity/ts-platform/issues"
  },
  "type": "module",
  "sideEffects": false,
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "types": "./dist/index.d.ts",
  "main": "./dist/index.js",
  "files": [
    "dist"
  ],
  "scripts": {
    "build:js": "tsup",
    "build:types": "tsc -p tsconfig.json --emitDeclarationOnly",
    "build": "pnpm build:js && pnpm build:types",
    "dev": "tsup --watch"
  },
  "dependencies": {
    "@codeminity/request-core": "workspace:*",
    "axios": "^1.18.1"
  },
  "devDependencies": {
    "tsup": "^8.5.1"
  }
}
